      "beta": [
        "devkit_scan",
        "devkit_sync",
        "devkit_query",
        "devkit_index",
        "devkit_note",
        "devkit_vault_write",
        "devkit_vault_backlinks",
        "devkit_natural_language_query",
        "devkit_github_info"
      ],
      "experimental": [
        "devkit_digest",
        "devkit_paper_index",
        "devkit_experiment_log",
        "devkit_code_metrics",
        "devkit_module_graph"
      ]
    }
