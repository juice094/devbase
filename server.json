  "version": "0.2.3",
  "description": "Developer Knowledge OS — manage Git repos, vault notes (Markdown), and assets. AI-native workspace with 19 MCP tools."
  "license": "MIT",
  "homepage": "https://github.com/juice094/devbase",
  "repository": {
    "type": "git",
    "url": "https://github.com/juice094/devbase.git"
  },
