    {
      "name": "juice094",
      "email": "160722440+juice094@users.noreply.github.com"
    }
  ],
  "categories": ["developer-tools", "knowledge-management", "version-control"],
  "tags": ["git", "rust", "vault", "notes", "mcp"],
  "runtime": {
    "type": "stdio",
    "command": "devbase",
    "args": ["mcp"]
  },
  "installation": {
    "cargo": {
      "crate": "devbase",
      "bin": "devbase"
    }
  },
